# Copy this file to `.env` next to relay.py and fill in the values.
# relay.py reads .env on startup (and falls back to real env vars).

# ── Supabase (required) ──────────────────────────────────────────────────
# The clubhouse Supabase project. The service_role key is used because the
# relay runs on a trusted bay PC and writes to `shots` / `sessions` rows
# under arbitrary player_ids. Never check the .env into git.
CLUBHOUSE_SUPABASE_URL=https://ufzmrvnunjmlqqwjqprq.supabase.co
CLUBHOUSE_SUPABASE_SERVICE_KEY=

# ── This bay ─────────────────────────────────────────────────────────────
# 1-indexed bay number for this PC. Stored on each `sessions` row.
CLUBHOUSE_BAY_NUMBER=1

# ── Ports / wiring ───────────────────────────────────────────────────────
# Port the relay listens on for the launch monitor. Point Uneekor View's
# GSPro target at <this PC>:9999 instead of localhost:921.
CLUBHOUSE_LM_PORT=9999

# Where the *real* GSPro is. Leave at 127.0.0.1:921 if GSPro runs on the
# same PC as the relay (default GSPro OpenAPI Connect port).
CLUBHOUSE_GSPRO_HOST=127.0.0.1
CLUBHOUSE_GSPRO_PORT=921

# Port the local web UI (player picker) listens on.
CLUBHOUSE_UI_PORT=8080

# ── Session behavior ─────────────────────────────────────────────────────
# Auto-close the current session after this many minutes without a shot.
CLUBHOUSE_SESSION_TIMEOUT_MIN=45
